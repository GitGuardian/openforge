# Supabase
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Server
PORT=3000

# App mode: "private" (all routes require auth) or "public" (browse is open)
OPENFORGE_MODE=public

# Allowed email domains for registration (comma-separated, private mode only)
# Leave empty for open registration
ALLOWED_DOMAINS=
